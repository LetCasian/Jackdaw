{
  "name": "jackdaw",
  "version": "1.2.0",
  "description": "Jackdaw - Collect what catches your eye. A reference companion for artists.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "keywords": [
    "moodboard",
    "reference",
    "artists",
    "photoshop",
    "always-on-top"
  ],
  "author": "Jackdaw",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jackdaw.app",
    "productName": "Jackdaw",
    "copyright": "Copyright © 2026 Jackdaw",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jackdaw"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.icns",
      "category": "public.app-category.graphics-design"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png",
      "category": "Graphics"
    }
  }
}
